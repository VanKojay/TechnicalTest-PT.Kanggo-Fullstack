PORT=5000

# ─── Database ───────────────────────────────────────────────
# Dialect: 'sqlite' (local dev, no external DB) | 'mysql' | 'postgres' (Supabase)
DB_DIALECT=sqlite

# --- Local dev (sqlite) ---
DB_STORAGE=./database.sqlite

# --- Production: Supabase / Railway / any managed Postgres ---
# Set DB_DIALECT=postgres and provide the full connection string.
# Get it from Supabase: Project Settings > Database > Connection string > "URI"
# IMPORTANT: use the CONNECTION POOLER URI (host ...pooler.supabase.com, port 6543)
# DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres

# --- Alternative: discrete MySQL/Postgres config (used only if DATABASE_URL is empty) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=kanggo_taskmanager

# ─── Auth ───────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=24h

# ─── CORS ───────────────────────────────────────────────────
# In production set this to your Vercel frontend URL, e.g. https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173
